# Qt/QML project ignores

# Qt Creator user files
*.pro.user
*.pro.user.*
*.creator
*.creator.user
*.creator.user.*
*.files
*.includes
*.config
*.cflags
*.cxxflags
*.qmake.stash
*.qmake.cache

# Common build output directories
/build-simulator/
/build-symbian/
/debug/
/release/
/bin/
/out/
/x86/
/x64/

# Generated Qt build artifacts
/moc/
/obj/
/rcc/
/ui/
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h
Makefile
Makefile.*

*.mmp
*.pkg
*.rss
*.loc

# Symbian qmake/raptor build artifacts (generated in repo root)
/bld.inf
/.make.cache

# Compiled objects and binaries
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll
*.exe
*.exp
*.ilk
*.pdb
*.idb

# QML caches
*.qmlc
*.jsc
*.qmlproject.user
*.qmlproject.user.*

# Logs and OS junk
*.log
.DS_Store
Thumbs.db
ehthumbs.db

# Ensure dependency blobs are kept in version control
!deps/**

# Xyz_template.pkg is generated by qmake (it clobbers any committed copy), so it is
# left ignored by the *.pkg rule above and regenerated by build-symbian.ps1.

# Claude Code local config + agent worktrees
.claude/
